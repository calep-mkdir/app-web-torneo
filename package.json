{
  "name": "app-web-torneo",
  "version": "0.1.0",
  "description": "Plataforma web para gestionar torneos y mostrarlos en tiempo real.",
  "private": true,
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.104.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.8.0",
    "luxon": "3.7.2",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "server-only": "0.0.1",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "postcss": "8.5.10",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
